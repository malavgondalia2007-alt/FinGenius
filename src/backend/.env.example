
# ============================================================
# FinGenius Backend Environment Variables
# ============================================================
# Copy this file to .env:  cp .env.example .env

# Database (PostgreSQL recommended, SQLite fallback if omitted)
# For Docker:   postgresql://fingenius:fingenius_password@postgres:5432/fingenius_db
# For Local:    postgresql://fingenius:fingenius_password@localhost:5432/fingenius_db
# For SQLite:   sqlite:///./fingenius.db
DATABASE_URL=postgresql://fingenius:fingenius_password@localhost:5432/fingenius_db

# JWT Secret Key (CHANGE THIS in production!)
SECRET_KEY=your-secret-key-change-in-production-make-it-long

# JWT Settings (defaults are fine)
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000
