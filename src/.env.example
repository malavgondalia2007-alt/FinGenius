VITE_API_URL=http://localhost:8000
VITE_GROQ_API_KEY=your_groq_api_key_here

# Google Gemini AI API Key (fallback AI provider - free from aistudio.google.com)
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# NOTE: Groq AI (Llama 3.3) is the PRIMARY AI provider.
# The Groq API key is configured in services/geminiAI.ts.
# Gemini is used as a fallback if Groq is unavailable.

# ============================================================
# STOCK DATA — 100% Backend Web Scraping (No External APIs)
# ============================================================
# All stock data is fetched via YOUR backend's web scraping.
# No third-party stock API keys are needed.
# The frontend calls VITE_API_URL/stocks/quotes which your
# backend handles via Google Finance scraping.
#
# To start the backend:
#   cd backend && pip install -r requirements.txt && uvicorn app.main:app --reload
#
# You can customize the scraping logic in:
#   backend/app/api/stocks.py